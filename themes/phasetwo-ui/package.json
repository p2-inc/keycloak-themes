{
  "name": "phasetwo-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "keycloakify sync-extensions",
    "generate:api": "openapi-typescript https://raw.githubusercontent.com/p2-inc/phasetwo-docs/main/openapi.yaml -o src/admin/phaseII/api/phasetwo-schema.d.ts",
    "dev": "vite",
    "build": "tsc -b && vite build && keycloakify build",
    "build:app": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start-keycloak": "keycloakify start-keycloak",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:integration": "PLAYWRIGHT_INTEGRATION=true playwright test",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "docker:logs": "docker compose -f docker/docker-compose.yml logs -f keycloak"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.8",
